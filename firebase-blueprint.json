{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "customer"] },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Details of a product in the store",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "stock": { "type": "number" },
        "inStock": { "type": "boolean" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["name", "price", "createdAt", "updatedAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": {
          "type": "array",
          "items": { "type": "object" }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "shipped", "delivered", "cancelled"] },
        "paymentMethod": { "type": "string", "enum": ["COD"] },
        "shippingDetails": { "type": "object" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["userId", "items", "totalAmount", "status", "paymentMethod", "shippingDetails", "createdAt", "updatedAt"]
    },
    "BrandingSettings": {
      "title": "BrandingSettings",
      "description": "Website branding and design configurations",
      "type": "object",
      "properties": {
        "faviconUrl": { "type": "string", "description": "URL of the website favicon/tab icon" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Store users and admins (tied to Auth UUID)"
    },
    "/users/{userId}/savedRecipes/{recipeId}": {
      "schema": {
        "title": "SavedRecipe",
        "type": "object",
        "properties": {
          "recipeMarkdown": { "type": "string" },
          "createdAt": { "type": "number" }
        },
        "required": ["recipeMarkdown", "createdAt"]
      },
      "description": "User's saved recipes"
    },
    "/users/{userId}/recipeChat/{chatId}": {
      "schema": {
        "title": "RecipeChat",
        "type": "object",
        "properties": {
          "messages": {
            "type": "array",
            "items": { "type": "object" }
          },
          "updatedAt": { "type": "number" }
        },
        "required": ["messages", "updatedAt"]
      },
      "description": "User's AI Chef chat history sessions"
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Global catalog of products"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "All submitted orders"
    },
    "/settings/{settingId}": {
      "schema": { "$ref": "#/entities/BrandingSettings" },
      "description": "Global website settings, categories config, category images and branding"
    }
  }
}
